{
  "name": "@aurabx/standalone-uploader",
  "version": "1.0.1",
  "description": "Standalone DICOM uploader component for embedding in external applications",
  "type": "module",
  "main": "dist/standalone-auraloader.umd.js",
  "module": "dist/standalone-auraloader.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/standalone-auraloader.es.js",
      "require": "./dist/standalone-auraloader.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --declaration --outDir dist/types --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "example": "vite preview --open /examples/index.html"
  },
  "keywords": [
    "dicom",
    "uploader",
    "medical-imaging",
    "aurabox"
  ],
  "author": "Aurabx",
  "license": "MIT",
  "packageManager": "pnpm@10.23.0",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.1.4",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@uppy/core": "^5.2.0",
    "@uppy/drag-drop": "^5.1.0",
    "@uppy/status-bar": "^5.1.0",
    "@uppy/tus": "^5.1.1",
    "@zip.js/zip.js": "^2.8.26",
    "axios": "^1.15.1",
    "dicom-parser": "^1.8.21",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "@aurabx/uploader-client": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@aurabx/uploader-client": {
      "optional": true
    }
  }
}
